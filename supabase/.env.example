# Supabase Edge Functions、またはWEB版/Vercelのサーバー処理だけで使用する例です。
# このファイルの値をEXPO_PUBLIC_*へコピーしないでください。

APP_ENV=development
APP_TIMEZONE=Asia/Tokyo

# Supabase Edge FunctionsではSUPABASE_URL等が自動注入されます。
# ローカル実行時のみ設定し、本番のsecret keyはSecretsへ登録します。
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SECRET_KEY=
# 旧形式を使う環境だけ。SUPABASE_SECRET_KEYとの併用は不要です。
SUPABASE_SERVICE_ROLE_KEY=

# WEB版と同じメールプロバイダ設定
# none / resend / google_smtp
EMAIL_PROVIDER=google_smtp
EMAIL_FROM="Dミセ <noreply@example.com>"
EMAIL_REPLY_TO=support@example.com
EMAIL_NOTIFICATIONS_DEFAULT_ENABLED=false

# EMAIL_PROVIDER=resend
RESEND_API_KEY=

# EMAIL_PROVIDER=google_smtp
GOOGLE_SMTP_HOST=smtp-relay.gmail.com
GOOGLE_SMTP_PORT=587
GOOGLE_SMTP_SECURE=false
GOOGLE_SMTP_USER=
GOOGLE_SMTP_PASS=

# Expo Push ServiceのAccess Token securityを有効にした場合だけ設定
EXPO_ACCESS_TOKEN=
EXPO_PUSH_API_URL=https://exp.host/--/api/v2/push/send
