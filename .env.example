# WEB版（digital-shifts-webapp）の公開環境変数から、
# スタッフ向けネイティブアプリで使用するものだけをExpo用の名前へ対応付けています。
# EXPO_PUBLIC_*はアプリへ埋め込まれるため、秘密情報は設定しないでください。

# 必須: WEB版 NEXT_PUBLIC_SUPABASE_URL / NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY と同じ値
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# 共通プロダクト設定
# WEB版 NEXT_PUBLIC_APP_URL（例: https://dmise.example.com）
EXPO_PUBLIC_WEB_APP_URL=
# WEB版 NEXT_PUBLIC_APP_NAME（未設定時は「Dミセ」）
EXPO_PUBLIC_APP_NAME=

# Push通知（EASプロジェクト作成後に設定）
# EAS Dashboard / app.json の extra.eas.projectId に表示されるUUID
EXPO_PUBLIC_EAS_PROJECT_ID=
# Project IDとiOS/AndroidのPush credentialsを設定するまではfalse
EXPO_PUBLIC_PUSH_NOTIFICATIONS_ENABLED=false

# 意図的に含めないもの:
# SUPABASE_SECRET_KEY / SUPABASE_SERVICE_ROLE_KEY / SUPABASE_JWT_SECRET
# RESEND_* / EMAIL_* / GOOGLE_SMTP_* / STRIPE_SECRET_KEY / STRIPE_WEBHOOK_SECRET
# STRIPE_PRICE_* / STRIPE_PRODUCT_* / CRON_SECRET / WEBHOOK_SECRET
# これらはWEB版サーバー専用で、モバイルアプリへ埋め込んではいけません。
# サーバー側の例は supabase/.env.example に分離しています。
#
# WEB版lib/env.tsにはNEXT_PUBLIC_ENABLE_*も定義されていますが、
# 現在のWEB版コードでは機能分岐に使われていないため、モバイル版へは持ち込みません。
# スタッフ機能の可否は、既存DBのテナント契約・権限・feature overrideから判定します。
